# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/depart

# Auth
SECRET_KEY=your-secret-key-at-least-32-chars-long
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Apple Sign In
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id

# Google Routes API
GOOGLE_ROUTES_API_KEY=your-google-routes-api-key

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase (path to service account JSON)
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

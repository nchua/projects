# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/depart

# Auth
SECRET_KEY=your-secret-key-at-least-32-chars-long
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Apple Sign In
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id

# Apple MapKit Server API
APPLE_MAPKIT_KEY_ID=your-mapkit-key-id
APPLE_MAPKIT_PRIVATE_KEY=your-mapkit-es256-private-key-pem

# Redis
REDIS_URL=redis://localhost:6379/0

# APNs (direct push notifications)
APNS_KEY_ID=your-apns-key-id
APNS_BUNDLE_ID=io.departnudge.app
APNS_USE_SANDBOX=true

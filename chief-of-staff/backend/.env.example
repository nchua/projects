# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./chief_of_staff.db
# DATABASE_URL=postgresql://user:password@localhost:5432/jarvis

# Auth — generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Redis (for ARQ background worker)
REDIS_URL=redis://localhost:6379/0

# Anthropic — required for memory extraction + briefing AI insights
ANTHROPIC_API_KEY=

# Token encryption — required for OAuth integrations
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── OAuth Setup ──────────────────────────────────────────────
# First-time setup required for each provider. See below for steps.
#
# Google (Calendar + Gmail):
#   1. https://console.cloud.google.com → Create project
#   2. Enable "Google Calendar API" and "Gmail API"
#   3. OAuth consent screen → External → Add your email as test user
#   4. Credentials → Create OAuth Client ID (Web application)
#   5. Add redirect URIs:
#        http://localhost:3000/callback       (browser dev)
#        http://localhost/callback             (covers all localhost ports for Tauri)
#   6. Copy Client ID + Secret below
#   Note: gmail.readonly is restricted — tokens expire every 7 days in test mode
#
# GitHub:
#   1. https://github.com/settings/developers → OAuth Apps → New
#   2. Homepage URL: http://localhost:3000
#   3. Callback URL: http://localhost:19284/callback  (Tauri desktop fixed port)
#   4. Copy Client ID, generate + copy Client Secret below
#
# Slack:
#   1. https://api.slack.com/apps → Create New App → From scratch
#   2. OAuth & Permissions → Add redirect URL: http://localhost:19284/callback
#   3. Add User Token Scopes: channels:read, groups:read, im:read, mpim:read,
#      channels:history, groups:history, im:history, users:read
#   4. Basic Information → Copy Client ID + Secret below

# Google OAuth (Gmail + Calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (notification sync)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack OAuth (message sync)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Granola (local meeting notes)
GRANOLA_CACHE_PATH=

# Security — restrict redirect URIs in production
# OAUTH_REDIRECT_URIS=["https://your-frontend.com/callback"]

# CORS — restrict in production
CORS_ORIGINS=["*"]

# App
APP_NAME=Jarvis
APP_VERSION=0.1.0

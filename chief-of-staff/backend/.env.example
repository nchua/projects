# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chief_of_staff

# Auth
SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (for ARQ worker)
REDIS_URL=redis://localhost:6379/0

# Anthropic (AI extraction)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# APNs
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_AUTH_KEY_PATH=
APNS_TOPIC=com.nickchua.chiefofstaff
APNS_USE_SANDBOX=true

# App
APP_NAME=Chief of Staff
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# Worker
WORKER_DB_POOL_SIZE=10
WORKER_DB_MAX_OVERFLOW=40
